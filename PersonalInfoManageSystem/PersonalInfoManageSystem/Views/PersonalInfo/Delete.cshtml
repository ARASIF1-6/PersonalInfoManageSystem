@model PersonalInfoManageSystem.Models.PersonalInfo

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-4">

    <h3 class="text-danger">Are you sure you want to delete this?</h3>

    <div class="card shadow p-4">

        <dl class="row">

            <dt class="col-sm-3">First Name</dt>
            <dd class="col-sm-9">@Model.FirstName</dd>

            <dt class="col-sm-3">Last Name</dt>
            <dd class="col-sm-9">@Model.LastName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.PhoneNumber</dd>

            <dt class="col-sm-3">Nationality</dt>
            <dd class="col-sm-9">@Model.Nationality</dd>

        </dl>

        <form asp-action="Delete" method="post">

            <input type="hidden" asp-for="Id" />

            <button type="submit" class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>
</div>
